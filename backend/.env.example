# ── Anthropic (required) ─────────────────────────────────────────
# Powers all AI features: ICP generation, persona creation, conversation replies
ANTHROPIC_API_KEY=sk-ant-...

# ── Unipile (Phase 4+) ────────────────────────────────────────────
# LinkedIn account management, messaging, inbox sync, scraping
UNIPILE_API_KEY=
UNIPILE_DSN=

# ── Apollo.io (Phase 3+) ──────────────────────────────────────────
# Lead database (300M+ contacts) and enrichment
APOLLO_API_KEY=

# ── Trigify (Phase 2+) ────────────────────────────────────────────
# Real-time LinkedIn intent signal monitoring for Signal Agents
TRIGIFY_API_KEY=

# ── Redis (Phase 5+) ─────────────────────────────────────────────
# BullMQ message queue for paced outbound sending
REDIS_URL=redis://localhost:6379

# ── Supabase (Phase 1+) ───────────────────────────────────────────
# Authentication and future database
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Server ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
